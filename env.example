# ============================================================
# RAG Chatbot — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# LLM PRIORITY ORDER:
#   1. Groq  (fastest — recommended for most users)
#   2. OpenAI (best quality — requires paid account)
#   3. Neither set = local FLAN-T5 (slow on CPU, no API needed)
# ============================================================


# ------------------------------------------------------------
# OPTION 1: Groq (Recommended)
# Get a free key at: https://console.groq.com
# Free tier: 14,400 requests/day — plenty for personal use
# Speed: ~1 second per response
# ------------------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192
# Other fast Groq models: mixtral-8x7b-32768, gemma2-9b-it


# ------------------------------------------------------------
# OPTION 2: OpenAI (Best quality)
# Get a key at: https://platform.openai.com
# Requires a paid account (roughly $0.002 per query with gpt-3.5)
# ------------------------------------------------------------
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-3.5-turbo


# ------------------------------------------------------------
# Qdrant Cloud  (online vector DB — used when internet is available)
# Get a free cluster at: https://cloud.qdrant.io  (no credit card)
# Leave empty to use FAISS local storage instead
# ------------------------------------------------------------
QDRANT_URL=https://xxxx-xxxx.us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here


# ------------------------------------------------------------
# Embeddings (no change needed — free HuggingFace model)
# ------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2


# ------------------------------------------------------------
# RAG Settings (optional tuning)
# ------------------------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
RETRIEVAL_K=3            # Final docs passed to LLM after reranking
RETRIEVAL_K_INITIAL=10   # Docs fetched from FAISS before reranking (fetch more, keep best)
SEARCH_TYPE=similarity


# ------------------------------------------------------------
# Reranker + CRAG Grading
# ------------------------------------------------------------
# Cross-encoder model for reranking retrieved chunks
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# CRAG grade thresholds (ms-marco scores range roughly -10 to +10)
# Chunks scoring below GRADE_AMBIGUOUS_THRESHOLD are discarded
# If best chunk < GRADE_AMBIGUOUS_THRESHOLD → refuse to answer (INCORRECT)
GRADE_CORRECT_THRESHOLD=-2.0
GRADE_AMBIGUOUS_THRESHOLD=-5.0

# Rewrite follow-up questions as standalone before retrieval (true/false)
CONDENSE_QUESTIONS=true

# Split complex multi-part questions into sub-queries before retrieval (true/false)
DECOMPOSE_QUERIES=true

# ------------------------------------------------------------
# Semantic Cache (in-memory, per loaded document)
# ------------------------------------------------------------
# Cosine similarity threshold — questions above this score return cached answers
# 0.92 = very similar, 0.85 = loosely similar
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_SIZE=100

# ------------------------------------------------------------
# Redis  (persistent semantic cache — survives app restarts)
# ------------------------------------------------------------
# Local Redis (after: brew services start redis)
REDIS_URL=redis://localhost:6379
# Redis Cloud free tier: redis://:password@host:port
# Leave empty to use in-memory cache instead
REDIS_CACHE_TTL=86400   # seconds — 86400 = 24 hours


# ------------------------------------------------------------
# LLM Generation Settings
# ------------------------------------------------------------
LLM_TEMPERATURE=0.3
LLM_MAX_LENGTH=512


# ------------------------------------------------------------
# RAGAS Evaluation  (answer quality scoring — on demand)
# pip install ragas datasets
# Set true to enable the "Evaluate Last Answer" button in the UI
# Uses your configured LLM (Groq) as judge — no extra API key needed
# ------------------------------------------------------------
RAGAS_EVAL=false

# HyDE — Hypothetical Document Embeddings (improves conceptual query recall)
# Generates a hypothetical answer, embeds that instead of the raw question
# Adds ~1 extra LLM call per query — disable if latency is critical
HYDE_ENABLED=false

# How many prior Q&A turns to include in the LLM answer prompt
# 0 = no history passed to LLM, 2 = last 2 exchanges (recommended)
HISTORY_TURNS=2


# ------------------------------------------------------------
# LangSmith  (chain tracing & latency — optional observability)
# Get a free key at: https://smith.langchain.com
# When LANGCHAIN_API_KEY is set, all LangChain calls are auto-traced
# ------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=rag-chatbot-v2
